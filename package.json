{
  "name": "test_allur_ci_cd",
  "version": "1.0.0",
  "description": "test + CI/CD + Allure",
  "repository": {
    "type": "git",
    "url": "https://github.com/hannarim-23/test_allur_CI_CD"
  },
  "license": "ISC",
  "author": "hannarim-23",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ci": "npx playwright test --workers=1",
    "report": "npx playwright show-report",

    "allure:generate": "npx allure generate allure-results -o allure-report --clean",
    "allure:open": "npx allure open allure-report",
    "allure:test": "npm run test && npm run allure:generate && npm run allure:open",
     "allure:clean": "rm -rf allure-results allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "allure-commandline": "^2.42.1",
    "allure-playwright": "^3.10.0"
  }
}
